<article>
    <header>
        <nav>
            <h4>
                <a href="{{ provider_info.url }}">{{ provider_info.name }}</a>
            </h4>
        </nav>
    </header>
    <p>{{ provider_info.description }}, {{ provider_info.region.local_name }}</p>

    {% if provider_info.Configuration.model_fields %}
        <details>
            <summary>
                <strong>Configuration</strong>
            </summary>
            <ul>
                {% for name, field_info in provider_info.Configuration.model_fields.items() %}
                    <li>
                        <strong>{{ name }}</strong>
                        {% if not field_info.is_required() %}
                            ({{ field_info.get_default() }})
                        {% else %}
                            *
                        {% endif %}
                        :
                        {{ field_info.description }}
                    </li>
                {% endfor %}
            </ul>
        </details>
    {% endif %}
</article>
